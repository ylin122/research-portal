{
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "autoUpdatesChannel": "latest",
  "enableAllProjectMcpServers": false,
  "effortLevel": "xhigh",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "RP=$HOME/projects/research-portal; [ -d \"$RP\" ] || RP=$HOME/research-portal; [ -d \"$RP\" ] && cd \"$RP\" && node scripts/sync-agents.cjs",
            "timeout": 30,
            "statusMessage": "Syncing agents + dotclaude..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/log-subagent-run.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/hooks/log-user-prompt.cjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
