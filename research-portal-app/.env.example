# ─── Client (browser) — these are bundled into the JS, treat as public ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Server-only (Vercel Functions) — never prefixed with VITE_ ───
# /api/financials uses these to verify the Supabase JWT on each request.
# The function reads SUPABASE_URL / SUPABASE_ANON_KEY first, then falls back
# to the VITE_* values above.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
