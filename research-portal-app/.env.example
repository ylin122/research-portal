# ─── Client (browser) — these are bundled into the JS, treat as public ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Server-only (Vercel Functions) — never prefixed with VITE_ ───
# Anthropic key for the /api/claude proxy. Set in Vercel env.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional server-side Supabase fallback (the function reads SUPABASE_URL /
# SUPABASE_ANON_KEY first, then falls back to the VITE_* values above).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
